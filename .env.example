# Copy to ".env" and fill in — docker compose loads this into the bot container.

# Required: Telegram bot token from @BotFather.
BOT_TOKEN=your_bot_token_here

# Optional: Agnes AI (OpenAI-compatible) for natural-language due dates /
# reminder schedules. Leave blank to fall back to strict YYYY-MM-DD HH:MM.
AGNES_AI_TOKEN=
# AGNES_AI_BASE_URL=https://apihub.agnes-ai.com/v1
# AGNES_AI_MODEL=agnes-2.0-flash
