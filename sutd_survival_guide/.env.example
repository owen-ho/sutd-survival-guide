# Telegram bot token for the unified SUTD Survival Guide bot.
# Get one from @BotFather on Telegram, then copy this file to ".env".
BOT_TOKEN=your_bot_token_here

# Agnes AI (OpenAI-compatible) — lets the deadline flow accept free-text due
# dates like "next Friday 2pm". Optional: leave the token blank to fall back to
# the strict YYYY-MM-DD HH:MM format. Base URL / model have working defaults.
AGNES_AI_TOKEN=your_agnes_api_token_here
# AGNES_AI_BASE_URL=https://apihub.agnes-ai.com/v1
# AGNES_AI_MODEL=agnes-2.0-flash